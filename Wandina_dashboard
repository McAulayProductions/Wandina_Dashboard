  else if(activeStrategyMode==='attack'&&debtReady==='Ready'){nextTitle='Attack mode is supported';nextBody=`Buffer is holding. You can review stronger PPOR attack or a ${currency(debtTarget)} debt-recycling structure without fantasy.`;}
  const floorStatus=floorGap8<0?'BELOW':floorGap8<3000?'NEAR':'SAFE';
  const strategySummary=`Weekly pressure is ${currency(totalPressure)} against income of ${currency(income)}. ${verdict==='OFF TRACK'?'The system is currently failing and must be tightened before any strategic move.':verdict==='TIGHT'?'The system is functioning, but the buffer is weak and one sloppy week will hurt.':'The system is currently holding, but discipline still matters more than optimism.'} Active strategy mode: ${activeStrategyMode.toUpperCase()}. Offset floor status: ${floorStatus}. Refinance: ${refinance}. Sell: ${sell}. Debt recycling: ${debtReady}. 2027 readiness: ${futureReady}.`;
